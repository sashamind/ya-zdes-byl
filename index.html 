<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Я здесь был</title>
  <style>
    /* ── Сброс стилей и базовые настройки ── */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #000;
      overflow: hidden;
      font-family: 'Courier New', monospace;
    }

    /* ── Основной холст — на весь экран ── */
    #canvas {
      display: block;
      width: 100vw;
      height: 100vh;
    }

    /* ── Скрытое меню настроек ── */
    #settings {
      display: none; /* скрыто по умолчанию */
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0, 0, 0, 0.92);
      border: 1px solid #333;
      padding: 32px 40px;
      color: #fff;
      z-index: 100;
      min-width: 340px;
    }

    #settings.visible {
      display: block;
    }

    #settings h2 {
      font-size: 11px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 24px;
    }

    #settings label {
      display: block;
      font-size: 11px;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    #settings select {
      width: 100%;
      background: #111;
      color: #fff;
      border: 1px solid #333;
      padding: 10px 12px;
      font-size: 13px;
      font-family: 'Courier New', monospace;
      margin-bottom: 24px;
      appearance: none; /* убирает стрелку браузера */
      cursor: pointer;
    }

    #settings select:focus {
      outline: none;
      border-color: #666;
    }

    /* ── Кнопки в меню ── */
    .btn {
      background: transparent;
      color: #fff;
      border: 1px solid #444;
      padding: 10px 20px;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      font-family: 'Courier New', monospace;
      transition: border-color 0.2s;
    }

    .btn:hover {
      border-color: #fff;
    }

    .btn-primary {
      border-color: #fff;
      margin-right: 12px;
    }

    /* ── Подсказка в углу ── */
    #hint {
      position: fixed;
      bottom: 20px;
      right: 24px;
      font-size: 10px;
      letter-spacing: 2px;
      color: #222;
      text-transform: uppercase;
      font-family: 'Courier New', monospace;
      transition: color 0.3s;
    }

    #hint:hover {
      color: #555;
    }

    /* ── Индикатор статуса камеры ── */
    #status {
      position: fixed;
      top: 20px;
      left: 24px;
      font-size: 10px;
      letter-spacing: 2px;
      color: #222;
      text-transform: uppercase;
      font-family: 'Courier New', monospace;
    }
  </style>
</head>
<body>

  <!-- Холст — здесь рисуются буквы -->
  <canvas id="canvas"></canvas>

  <!-- Индикатор состояния -->
  <div id="status">● камера не активна</div>

  <!-- Подсказка как открыть меню -->
  <div id="hint">S — настройки</div>

  <!-- Скрытое меню настроек -->
  <div id="settings">
    <h2>Настройки</h2>
    <label for="cameraSelect">Камера</label>
    <select id="cameraSelect">
      <option value="">— поиск камер...</option>
    </select>
    <div>
      <button class="btn btn-primary" id="applyBtn">Применить</button>
      <button class="btn" id="closeBtn">Закрыть</button>
    </div>
  </div>

  <!--
    MediaPipe — библиотека от Google для отслеживания людей.
    Подключаем прямо из интернета, ничего устанавливать не нужно.
  -->
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js"></script>

  <script>
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // НАСТРОЙКИ — здесь можно менять поведение букв
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    const CONFIG = {
      text: 'Я ЗДЕСЬ БЫЛ',       // текст инсталляции
      fontSize: 80,               // размер шрифта в пикселях
      repelRadius: 180,           // радиус отталкивания (как далеко буква "чувствует" человека)
      repelStrength: 18,          // сила отталкивания (чем больше — тем сильнее разлетаются)
      returnSpeed: 0.04,          // скорость возврата на место (0.01 = медленно, 0.1 = быстро)
      friction: 0.82,             // трение (замедление букв, 0.9 = скользко, 0.7 = вязко)
      letterSpacing: 8,           // дополнительный отступ между буквами
    };

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // ИНИЦИАЛИЗАЦИЯ ХОЛСТА
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d'); // контекст — инструмент для рисования на холсте

    // Подстраиваем холст под размер окна браузера
    function resizeCanvas() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
      initLetters(); // пересчитываем позиции букв при изменении размера
    }

    window.addEventListener('resize', resizeCanvas);

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // БУКВЫ — создаём объект для каждой буквы текста
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    let letters = []; // массив (список) всех букв

    function initLetters() {
      letters = [];

      ctx.font = `${CONFIG.fontSize}px 'Courier New', monospace`;

      // Считаем общую ширину текста, чтобы отцентровать его
      const totalWidth = CONFIG.text.split('').reduce((sum, char) => {
        return sum + ctx.measureText(char).width + CONFIG.letterSpacing;
      }, 0);

      // Стартовая X-позиция — чтобы текст был по центру
      let startX = (canvas.width  - totalWidth) / 2;
      const startY = canvas.height / 2 + CONFIG.fontSize / 3; // вертикальный центр

      // Создаём объект для каждой буквы
      CONFIG.text.split('').forEach((char, i) => {
        const charWidth = ctx.measureText(char).width + CONFIG.letterSpacing;

        letters.push({
          char,                         // символ буквы
          homeX: startX + charWidth / 2, // "домашняя" X-позиция (куда возвращается)
          homeY: startY,                // "домашняя" Y-позиция
          x: startX + charWidth / 2,   // текущая X-позиция
          y: startY,                    // текущая Y-позиция
          vx: 0,                        // скорость по X (velocity — скорость)
          vy: 0,                        // скорость по Y
        });

        startX += charWidth;
      });
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // ТОЧКИ ТЕЛА — координаты суставов человека из MediaPipe
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    let bodyPoints = []; // список точек тела (нос, плечи, руки и т.д.)

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // ФИЗИКА — каждый кадр обновляем позиции букв
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    function updateLetters() {
      letters.forEach(letter => {

        // 1. Сила возврата домой — буква всегда тянется на своё место
        // Это как резинка: чем дальше буква, тем сильнее тянет
        const dx = letter.homeX - letter.x;
        const dy = letter.homeY - letter.y;
        letter.vx += dx * CONFIG.returnSpeed;
        letter.vy += dy * CONFIG.returnSpeed;

        // 2. Отталкивание от точек тела
        bodyPoints.forEach(point => {
          // Переводим координаты из камеры (0-1) в координаты экрана
          // Камера зеркальная, поэтому инвертируем X: (1 - point.x)
          const px = (1 - point.x) * canvas.width;
          const py = point.y * canvas.height;

          // Расстояние от буквы до точки тела
          const diffX = letter.x - px;
          const diffY = letter.y - py;
          const distance = Math.sqrt(diffX * diffX + diffY * diffY);

          // Если буква близко к точке тела — отталкиваем её
          if (distance < CONFIG.repelRadius && distance > 0) {
            // Сила обратно пропорциональна расстоянию:
            // близко = сильно толкает, далеко = слабо
            const force = (CONFIG.repelRadius - distance) / CONFIG.repelRadius;
            letter.vx += (diffX / distance) * force * CONFIG.repelStrength;
            letter.vy += (diffY / distance) * force * CONFIG.repelStrength;
          }
        });

        // 3. Применяем трение — буква постепенно замедляется
        letter.vx *= CONFIG.friction;
        letter.vy *= CONFIG.friction;

        // 4. Обновляем позицию
        letter.x += letter.vx;
        letter.y += letter.vy;
      });
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // РИСОВАНИЕ — каждый кадр очищаем и рисуем заново
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    function draw() {
      // Очищаем холст чёрным цветом
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Настройки шрифта
      ctx.font = `${CONFIG.fontSize}px 'Courier New', monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = '#fff'; // белые буквы

      // Рисуем каждую букву на её текущей позиции
      letters.forEach(letter => {
        ctx.fillText(letter.char, letter.x, letter.y);
      });
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // ГЛАВНЫЙ ЦИКЛ — requestAnimationFrame запускает
    // функцию ~60 раз в секунду (как кадры в видео)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    function loop() {
      updateLetters();
      draw();
      requestAnimationFrame(loop); // запрашиваем следующий кадр
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // MEDIAPIPE POSE — отслеживание скелета человека
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    let currentStream = null; // текущий поток с камеры
    const videoEl = document.createElement('video'); // скрытый видеоэлемент
    videoEl.style.display = 'none';
    document.body.appendChild(videoEl);

    // Создаём объект MediaPipe Pose
    const pose = new Pose({
      locateFile: (file) =>
        `https://cdn.jsdelivr.net/npm/@mediapipe/pose/${file}`,
    });

    // Настройки точности определения
    pose.setOptions({
      modelComplexity: 1,           // 0=быстро/неточно, 1=баланс, 2=медленно/точно
      smoothLandmarks: true,        // сглаживание движений
      minDetectionConfidence: 0.5,  // минимальная уверенность для обнаружения
      minTrackingConfidence: 0.5,   // минимальная уверенность для слежения
    });

    // Эта функция вызывается каждый раз, когда MediaPipe обработал кадр
    pose.onResults((results) => {
      if (results.poseLandmarks) {
        // poseLandmarks — массив из 33 точек тела (нос, уши, плечи, локти...)
        // Берём все точки с достаточной уверенностью
        bodyPoints = results.poseLandmarks
          .filter(p => p.visibility > 0.5) // оставляем только хорошо видимые точки
          .map(p => ({ x: p.x, y: p.y }));
      } else {
        bodyPoints = []; // человека нет в кадре
      }
    });

    // Запускаем камеру с выбранным deviceId
    async function startCamera(deviceId = null) {
      // Останавливаем предыдущий поток если был
      if (currentStream) {
        currentStream.getTracks().forEach(t => t.stop());
      }

      const constraints = {
        video: deviceId
          ? { deviceId: { exact: deviceId }, width: 1280, height: 720 }
          : { width: 1280, height: 720 },
      };

      try {
        currentStream = await navigator.mediaDevices.getUserMedia(constraints);
        videoEl.srcObject = currentStream;
        videoEl.play();

        // Обновляем статус
        document.getElementById('status').textContent = '● камера активна';
        document.getElementById('status').style.color = '#333';

        // Запускаем обработку кадров через MediaPipe Camera Utils
        const camera = new Camera(videoEl, {
          onFrame: async () => {
            await pose.send({ image: videoEl });
          },
          width: 1280,
          height: 720,
        });
        camera.start();

      } catch (err) {
        console.error('Ошибка камеры:', err);
        document.getElementById('status').textContent = '● ошибка камеры';
        document.getElementById('status').style.color = '#f00';
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // МЕНЮ НАСТРОЕК
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    const settingsEl = document.getElementById('settings');
    const selectEl   = document.getElementById('cameraSelect');

    // Получаем список всех доступных камер
    async function loadCameras() {
      try {
        // Сначала нужно попросить доступ к любой камере,
        // иначе браузер не покажет список устройств
        await navigator.mediaDevices.getUserMedia({ video: true });

        const devices = await navigator.mediaDevices.enumerateDevices();
        const cameras = devices.filter(d => d.kind === 'videoinput');

        selectEl.innerHTML = ''; // очищаем список

        cameras.forEach((cam, i) => {
          const option = document.createElement('option');
          option.value = cam.deviceId;
          option.textContent = cam.label || `Камера ${i + 1}`;
          selectEl.appendChild(option);
        });

      } catch (err) {
        console.error('Не удалось получить список камер:', err);
      }
    }

    // Открыть меню по нажатию S
    document.addEventListener('keydown', async (e) => {
      if (e.key === 's' || e.key === 'S' || e.key === 'ы' || e.key === 'Ы') {
        settingsEl.classList.toggle('visible');
        if (settingsEl.classList.contains('visible')) {
          await loadCameras(); // обновляем список камер при открытии
        }
      }
      // Закрыть по Escape
      if (e.key === 'Escape') {
        settingsEl.classList.remove('visible');
      }
    });

    // Кнопка «Применить» — запускаем выбранную камеру
    document.getElementById('applyBtn').addEventListener('click', () => {
      const selectedId = selectEl.value;
      startCamera(selectedId);
      settingsEl.classList.remove('visible');
    });

    // Кнопка «Закрыть»
    document.getElementById('closeBtn').addEventListener('click', () => {
      settingsEl.classList.remove('visible');
    });

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // СТАРТ
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    resizeCanvas(); // инициализируем холст и буквы
    loop();         // запускаем анимацию
    startCamera();  // запускаем камеру (первую доступную)

  </script>
</body>
</html>